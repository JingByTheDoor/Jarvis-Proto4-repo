{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "JARVIS — Local AI Operator Console (Electron desktop app)",
  "private": true,
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "webpack --config webpack.preload.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "electron dist/main/index.js",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "test": "jest --config jest.config.js",
    "lint": "eslint 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "css-loader": "^7.1.2",
    "electron": "^35.1.2",
    "eslint": "^9.24.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
