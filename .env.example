# JARVIS environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# LLM provider (openai | anthropic | local)
LLM_PROVIDER=openai

# API key for remote LLM provider (required if LLM_PROVIDER is openai or anthropic)
LLM_API_KEY=

# Model name override (optional)
LLM_MODEL=

# Max agent loop iterations (safety bound)
MAX_AGENT_LOOP=25

# Log level (debug | info | warn | error)
LOG_LEVEL=info
