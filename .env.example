# JARVIS environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# LLM provider (openai | anthropic)
LLM_PROVIDER=

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Max agent loop iterations (safety bound)
MAX_AGENT_LOOP=25

# Log level (debug | info | warn | error)
LOG_LEVEL=info
